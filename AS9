def caesar_cipher(filename, shift, direction, output_file):
    result = []
    with open(filename, 'r') as f:
        text = f.read()

    for char in text:
        if char.isalpha():
            base = 65 if char.isupper() else 97
            if direction == 'right':
                new_char = chr((ord(char) - base + shift) % 26 + base)
            else:  # left shift
                new_char = chr((ord(char) - base - shift) % 26 + base)
            result.append(new_char)
        else:
            result.append(char)

    with open(output_file, 'w') as f:
        f.write(''.join(result))
